# ---------------------------------------------------------------
# All values below are defaults for local development only.
# Set real values when deploying to a production environment.
# Never commit your actual .env file to version control.
# ---------------------------------------------------------------

API_KEY=change-this-to-a-strong-secret
REDIS_URL=redis://localhost:6379/0

# Optional: residential proxy to bypass datacenter IP blocks
# Format: socks5h://user:pass@host:port
PROXY_URL=

MAX_DURATION_SECONDS=3600
MAX_FILESIZE_MB=500
FILE_TTL_MINUTES=30
RATE_LIMIT_PER_MINUTE_IP=10
RATE_LIMIT_PER_MINUTE_KEY=30
MAX_CONCURRENT_DOWNLOADS=5
